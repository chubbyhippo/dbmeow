" ============================================================================
" .dbmeowrc — THE default keymap of the dbmeow plugin
" ----------------------------------------------------------------------------
" Like meow in Emacs, the plugin binds no keys in code: these lines ARE the
" default NORMAL/MOTION layout (meow's suggested QWERTY), plus the SPC
" keypad <action> table below —
" Eclipse workbench command ids verified against IWorkbenchCommandConstants
" or the installed DBeaver 26.1 plugin.xmls (Quick Access joined once its id
" and default handler verified there, 2026-07-11).
" A ~/.dbmeowrc overrides this file entry by entry.
" ============================================================================

set which-key
set timeoutlen=300

nmap 0 meow-expand-0
nmap 1 meow-expand-1
nmap 2 meow-expand-2
nmap 3 meow-expand-3
nmap 4 meow-expand-4
nmap 5 meow-expand-5
nmap 6 meow-expand-6
nmap 7 meow-expand-7
nmap 8 meow-expand-8
nmap 9 meow-expand-9
nmap - meow-negative-argument

" selections / things
nmap ; meow-reverse
nmap , meow-inner-of-thing
nmap . meow-bounds-of-thing
nmap [ meow-beginning-of-thing
nmap ] meow-end-of-thing
nmap < meow-beginning-of-thing
nmap > meow-end-of-thing

" the letter keys
nmap a meow-append
nmap A meow-open-below
nmap b meow-back-word
nmap B meow-back-symbol
nmap c meow-change
nmap d meow-delete
nmap D meow-backward-delete
nmap e meow-next-word
nmap E meow-next-symbol
nmap f meow-find
nmap g meow-cancel-selection
nmap G meow-grab
nmap h meow-left
nmap H meow-left-expand
nmap i meow-insert
nmap I meow-open-above
nmap j meow-next
nmap J meow-next-expand
nmap k meow-prev
nmap K meow-prev-expand
nmap l meow-right
nmap L meow-right-expand
nmap m meow-join
nmap n meow-search
nmap o meow-block
nmap O meow-to-block
nmap p meow-yank
nmap q meow-quit
nmap Q avy-goto-line
nmap r meow-replace
nmap R meow-swap-grab
nmap s meow-kill
nmap S avy-goto-char-timer
nmap t meow-till
nmap u meow-undo
nmap U meow-undo-in-selection
nmap v meow-visit
nmap w meow-mark-word
nmap W meow-mark-symbol
nmap x meow-line
nmap X meow-goto-line
nmap y meow-save
nmap Y meow-sync-grab
nmap z meow-pop-selection
nmap ' repeat
mmap j meow-next
mmap k meow-prev
mmap h meow-left
mmap l meow-right
mmap q <action>(dbmeow.hideView)

" ── SPC keypad table ────────────────────────────────────────────────────────
" SPC is the leader; these sequences dispatch Eclipse workbench commands. Ids
" verified against IWorkbenchCommandConstants (eclipse.platform.ui) or the
" installed DBeaver 26.1 plugin.xmls. SPC 1-9 = digit argument, SPC ? =
" cheatsheet, SPC / = describe-key (handled in code).
map <leader><Space> <action>(org.eclipse.ui.window.previousEditor)
desc <leader><Space> last editor

desc <leader>x files
" f = goto-file: Eclipse's Open Resource dialog
" (org.eclipse.ui.navigate.openResource, defined with a default handler in
" the installed DBeaver 26.1 org.eclipse.ui.ide plugin.xml, 2026-07-11)
map <leader>xf <action>(org.eclipse.ui.navigate.openResource)
map <leader>xs <action>(org.eclipse.ui.file.save)
map <leader>xS <action>(org.eclipse.ui.file.saveAll)
map <leader>xk <action>(org.eclipse.ui.file.close)
map <leader>xK <action>(org.eclipse.ui.file.closeAll)
map <leader>xr <action>(org.eclipse.ui.file.refresh)

desc <leader>w windows
map <leader>wn <action>(org.eclipse.ui.window.nextEditor)
map <leader>wp <action>(org.eclipse.ui.window.previousEditor)
map <leader>wh <action>(dbmeow.windmoveLeft)
map <leader>wj <action>(dbmeow.windmoveDown)
map <leader>wk <action>(dbmeow.windmoveUp)
map <leader>wl <action>(dbmeow.windmoveRight)
" zoom on SPC w i/o (no reset — Eclipse text editors
" only define zoomIn/zoomOut; ids verified in the installed DBeaver's
" org.eclipse.ui.workbench.texteditor plugin.xml, 2026-07-10)
map <leader>wi <action>(org.eclipse.ui.edit.text.zoomIn)
map <leader>w= <action>(org.eclipse.ui.edit.text.zoomIn)
map <leader>wo <action>(org.eclipse.ui.edit.text.zoomOut)
map <leader>w- <action>(org.eclipse.ui.edit.text.zoomOut)

desc <leader>e edit
map <leader>eu <action>(org.eclipse.ui.edit.undo)
map <leader>er <action>(org.eclipse.ui.edit.redo)
map <leader>ef <action>(org.eclipse.ui.edit.findReplace)

desc <leader>j jump
map <leader>jo <action>(org.eclipse.ui.navigate.backwardHistory)
map <leader>ji <action>(org.eclipse.ui.navigate.forwardHistory)

" SPC c m / M — edit and reload ~/.dbmeowrc. The
" dbmeow.* ids are adapter-mapped (EclipseUi.runCommand), not Eclipse
" commands; reload flushes a dirty rc editor first (Eclipse saves documents
" lazily; IdeaVim's ReloadVimRc saveDocumentAsIs precedent).
desc <leader>c config
map <leader>cm <action>(dbmeow.editRc)
map <leader>cM <action>(dbmeow.reloadRc)

" SPC m — meta, the M- group slots that verify here. m x =
" Quick Access, Eclipse's M-x analog (org.eclipse.ui.window
" .quickAccess, defined with a default handler in the installed DBeaver 26.1
" org.eclipse.ui plugin.xml, 2026-07-11 — absent until exactly this check).
" m o / m g are the native avy jumps on this prefix — core meow
" commands, no Eclipse id involved; m g is avy-goto-line rather than the
" native goto-line dialog.
desc <leader>m meta
map <leader>mx <action>(org.eclipse.ui.window.quickAccess)
map <leader>mo avy-goto-char-timer
map <leader>mg avy-goto-line

" SPC b — bookmarks. m sets a line bookmark;
" j opens the Bookmarks view to jump. Ids verified against the installed
" DBeaver (org.eclipse.ui.ide is bundled, so the marker infra + view exist);
" the parameterized showView flows through EclipseUi's deserialize path.
" An Emacs-style C-x r b bookmark list (an SPC x r b slot) is covered by
" SPC b j here — dbmeow's SPC x r is the
" file.refresh leaf, so no x r b prefix can exist; and numbered slots
" (SPC b 0-9) have no Eclipse analog: the installed 26.1 jars define only
" org.eclipse.ui.edit.addBookmark, no toggle-bookmark-N commands.
desc <leader>b bookmark (m set / j jump)
map <leader>bm <action>(org.eclipse.ui.edit.addBookmark)
map <leader>bj <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.ui.views.BookmarkView))

" SPC . / SPC , — next / prev annotation (error nav; Eclipse's
" Next/Previous walks the SQL editor's markers). Ids verified in the
" installed DBeaver's org.eclipse.ui plugin.xml, 2026-07-10.
desc <leader>. next (annotation / error)
map <leader>.e <action>(org.eclipse.ui.navigate.next)
desc <leader>, previous (annotation / error)
map <leader>,e <action>(org.eclipse.ui.navigate.previous)

" ============================================================================
" Repeat groups — Emacs repeat-mode, ported (repeat.el's transient maps)
" ----------------------------------------------------------------------------
" After any binding whose TARGET is listed in a group below — membership is
" the target, not the key, like the repeat-map property on an Emacs command —
" the next keypress is first looked up in that group: a member key
" re-dispatches its target and keeps the run alive; any other key (or ESC)
" ends the run and keeps its normal meaning (Emacs transient-keymap
" fall-through — nothing is swallowed, and there is no timeout). The entering
" keypad key needn't be a member: repeat.el's repeat-check-key 'no is the
" same idea. Syntax:
"   repeat <group> <key> <target>     target grammar = the map-line RHS
"   repeat <group> <key> ignore       give a bundled group's key back
" The Emacs repeat maps that port here: flymake -> error (annotation nav),
" text-scale -> zoom
" (no u/0 reset member — Eclipse has no zoom-reset command). Would-be
" change (VCS markers) and expand (smart select) groups have no verified
" DBeaver-SQL command ids, so they ship no dbmeow analog — likewise a
" show-current-change-marker binding: Eclipse
" quickdiff defines only toggle/revert commands (installed 26.1
" org.eclipse.ui.editors plugin.xml), nothing that pops the change at point.
" So: SPC . e then . . , walks annotations; SPC w i then i i i keeps zooming.
repeat error . <action>(org.eclipse.ui.navigate.next)
repeat error , <action>(org.eclipse.ui.navigate.previous)
repeat zoom i <action>(org.eclipse.ui.edit.text.zoomIn)
repeat zoom = <action>(org.eclipse.ui.edit.text.zoomIn)
repeat zoom o <action>(org.eclipse.ui.edit.text.zoomOut)
repeat zoom - <action>(org.eclipse.ui.edit.text.zoomOut)
