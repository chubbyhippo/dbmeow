" ============================================================================
" .dbmeowrc — THE default keymap of the dbmeow plugin
" ----------------------------------------------------------------------------
" The plugin binds no keys in code: these lines ARE the default NORMAL/MOTION
" layout (meow's suggested QWERTY), plus the SPC keypad <action> table of
" Eclipse workbench command ids.
" A ~/.dbmeowrc overrides this file entry by entry — only the lines you
" change matter; a deleted line falls back to the bundled default (bind
" `ignore` to disable a key). Open it with SPC c m — the first press creates
" ~/.dbmeowrc as a full copy of this file; reload after editing with SPC c M.
" Within this file, a later line for the same key wins.
" ============================================================================

set which-key
set timeoutlen=300

" expand / counts
nmap 0 meow-expand-0
nmap 1 meow-expand-1
nmap 2 meow-expand-2
nmap 3 meow-expand-3
nmap 4 meow-expand-4
nmap 5 meow-expand-5
nmap 6 meow-expand-6
nmap 7 meow-expand-7
nmap 8 meow-expand-8
nmap 9 meow-expand-9
nmap - meow-negative-argument

" selections / things
nmap ; meow-reverse
nmap , meow-inner-of-thing
nmap . meow-bounds-of-thing
nmap [ meow-beginning-of-thing
nmap ] meow-end-of-thing
nmap < meow-beginning-of-thing
nmap > meow-end-of-thing

" the letter keys
nmap a meow-append
nmap A meow-open-below
nmap b meow-back-word
nmap B meow-back-symbol
nmap c meow-change
nmap d meow-delete
nmap D meow-backward-delete
nmap e meow-next-word
nmap E meow-next-symbol
nmap f meow-find
nmap g meow-cancel-selection
nmap G meow-grab
nmap h meow-left
nmap H meow-left-expand
nmap i meow-insert
nmap I meow-open-above
nmap j meow-next
nmap J meow-next-expand
nmap k meow-prev
nmap K meow-prev-expand
nmap l meow-right
nmap L meow-right-expand
nmap m meow-join
nmap n meow-search
nmap o meow-block
nmap O meow-to-block
nmap p meow-yank
nmap q meow-quit
nmap Q avy-goto-line
nmap r meow-replace
nmap R meow-swap-grab
nmap s meow-kill
nmap S avy-goto-char-timer
nmap t meow-till
nmap u meow-undo
nmap U meow-undo-in-selection
nmap v meow-visit
nmap w meow-mark-word
nmap W meow-mark-symbol
nmap x meow-line
nmap X meow-goto-line
nmap y meow-save
nmap Y meow-sync-grab
nmap z meow-pop-selection
nmap ' repeat

" MOTION mode — the keymap of workbench trees: j/k/h/l move, q hides the
" view, every unmapped key keeps its native meaning
mmap j meow-next
mmap k meow-prev
mmap h meow-left
mmap l meow-right
mmap q <action>(dbmeow.hideView)

" ── SPC keypad table ────────────────────────────────────────────────────────
" SPC is the leader; these sequences dispatch Eclipse workbench commands.
" SPC 1-9 = digit argument, SPC ? = cheatsheet, SPC / = describe-key
" (handled in code).
map <leader><Space> <action>(org.eclipse.ui.window.previousEditor)
desc <leader><Space> last editor

desc <leader>x C-x · files / buffers / splits
" f = goto-file: Eclipse's Open Resource dialog
map <leader>xf <action>(org.eclipse.ui.navigate.openResource)
map <leader>xj <action>(org.eclipse.ui.navigate.showIn(org.eclipse.ui.navigate.showIn.targetId=org.jkiss.dbeaver.core.projectExplorer))
" SPC x z = C-x z: repeat the last command (then bare z keeps repeating)
map <leader>xz repeat
map <leader>xo <action>(dbmeow.aceWindow)
map <leader>xb <action>(org.eclipse.ui.window.openEditorDropDown)
map <leader>xd <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.jkiss.dbeaver.core.databaseNavigator))
map <leader>xs <action>(org.eclipse.ui.file.save)
map <leader>xS <action>(org.eclipse.ui.file.saveAll)
map <leader>xk <action>(org.eclipse.ui.file.close)
map <leader>xK <action>(org.eclipse.ui.file.closeAll)
map <leader>xr <action>(org.eclipse.ui.file.refresh)
map <leader>xu <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.team.ui.GenericHistoryView))
map <leader>x2 <action>(org.eclipse.ui.window.splitEditor(Splitter.isHorizontal=true))
map <leader>x3 <action>(org.eclipse.ui.window.splitEditor(Splitter.isHorizontal=false))

desc <leader>xp C-x p · project
map <leader>xpf <action>(org.eclipse.ui.navigate.openResource)
map <leader>xpb <action>(org.eclipse.ui.window.openEditorDropDown)
map <leader>xpg <action>(org.eclipse.search.ui.openFileSearchPage)

desc <leader>xr C-x r · bookmarks
map <leader>xrb <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.ui.views.BookmarkView))

desc <leader>w window / splits / zoom
map <leader>ww <action>(dbmeow.aceWindow)
map <leader>wn <action>(org.eclipse.ui.window.nextEditor)
map <leader>wp <action>(org.eclipse.ui.window.previousEditor)
map <leader>w. <action>(org.eclipse.ui.window.nextEditor)
map <leader>w, <action>(org.eclipse.ui.window.previousEditor)
map <leader>wh <action>(dbmeow.windmoveLeft)
map <leader>wj <action>(dbmeow.windmoveDown)
map <leader>wk <action>(dbmeow.windmoveUp)
map <leader>wl <action>(dbmeow.windmoveRight)
" v/s: split the editor side-by-side / stacked (run again to unsplit)
map <leader>wv <action>(org.eclipse.ui.window.splitEditor(Splitter.isHorizontal=false))
map <leader>ws <action>(org.eclipse.ui.window.splitEditor(Splitter.isHorizontal=true))
" zoom on SPC w i/o (no reset — Eclipse defines only zoomIn/zoomOut)
map <leader>wi <action>(org.eclipse.ui.edit.text.zoomIn)
map <leader>w= <action>(org.eclipse.ui.edit.text.zoomIn)
map <leader>wo <action>(org.eclipse.ui.edit.text.zoomOut)
map <leader>w- <action>(org.eclipse.ui.edit.text.zoomOut)

desc <leader>e edit / folding
map <leader>eu <action>(org.eclipse.ui.edit.undo)
map <leader>er <action>(org.eclipse.ui.edit.redo)
map <leader>ef <action>(org.eclipse.ui.edit.findReplace)
map <leader>ea <action>(org.eclipse.ui.edit.text.folding.expand_all)
map <leader>et <action>(org.eclipse.ui.edit.text.folding.toggle)

desc <leader>f find / format / new
map <leader>fe <action>(org.eclipse.ui.navigate.showInQuickMenu)
map <leader>ff <action>(org.eclipse.search.ui.openFileSearchPage)
map <leader>fi <action>(org.eclipse.ui.edit.findReplace)
map <leader>fm <action>(org.jkiss.dbeaver.ui.editors.text.content.format)
map <leader>fn <action>(org.eclipse.ui.file.newQuickMenu)
map <leader>fo <action>(org.jkiss.dbeaver.ui.editors.text.content.format)
map <leader>fr <action>(org.eclipse.ui.window.openEditorDropDown)

desc <leader>g goto / history
map <leader>gd <action>(org.jkiss.dbeaver.ui.editors.sql.navigate.object)
map <leader>gh <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.team.ui.GenericHistoryView))

desc <leader>h maximize editor (hide views)
map <leader>h <action>(org.eclipse.ui.window.maximizePart)

desc <leader>j jump
map <leader>jo <action>(org.eclipse.ui.navigate.backwardHistory)
map <leader>ji <action>(org.eclipse.ui.navigate.forwardHistory)
map <leader>jl <action>(org.eclipse.ui.edit.text.goto.line)
map <leader>jb <action>(org.jkiss.dbeaver.ui.editors.sql.gotoMatchingBracket)

desc <leader>k key bindings
map <leader>k <action>(org.eclipse.ui.window.showKeyAssist)

desc <leader>l local history
map <leader>lh <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.team.ui.GenericHistoryView))

" SPC c m / M — edit and reload ~/.dbmeowrc; reload saves a dirty rc editor
" first
desc <leader>c C-c · commands / config
map <leader>cf <action>(org.eclipse.ui.navigate.openResource)
map <leader>cs <action>(org.eclipse.ui.file.saveAll)
map <leader>ck <action>(org.eclipse.ui.file.close)
map <leader>cr <action>(org.eclipse.search.ui.openFileSearchPage)
map <leader>ca <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.ui.views.TaskList))
map <leader>cc <action>(org.jkiss.dbeaver.core.sql.editor.create)
map <leader>cm <action>(dbmeow.editRc)
map <leader>cM <action>(dbmeow.reloadRc)

desc <leader>cj C-c j · avy jump
map <leader>cjw avy-goto-char-timer
map <leader>cjc avy-goto-char-timer
map <leader>cjl avy-goto-line

" SPC m = M-: meta — m x Quick Access (Eclipse's M-x), m , = M-, go back,
" m . = M-. goto declaration, m o / m g = the avy jumps on this prefix
desc <leader>m M- · meta
map <leader>mx <action>(org.eclipse.ui.window.quickAccess)
map <leader>mo avy-goto-char-timer
map <leader>m, <action>(org.eclipse.ui.navigate.backwardHistory)
map <leader>m. <action>(org.jkiss.dbeaver.ui.editors.sql.navigate.object)
map <leader>mg avy-goto-line

desc <leader>ms M-s · search
map <leader>msr <action>(org.eclipse.search.ui.openFileSearchPage)
map <leader>msl <action>(org.eclipse.ui.edit.findReplace)
map <leader>mss <action>(org.eclipse.ui.edit.findReplace)
map <leader>msL <action>(org.eclipse.search.ui.openFileSearchPage)
map <leader>mso <action>(org.jkiss.dbeaver.ui.editors.sql.show.outline)

desc <leader>n new
map <leader>nc <action>(org.jkiss.dbeaver.core.new.connection)
map <leader>nd <action>(org.jkiss.dbeaver.core.new.folder)
map <leader>nf <action>(org.eclipse.ui.file.newQuickMenu)
map <leader>ns <action>(org.jkiss.dbeaver.core.sql.editor.create)

desc <leader>o open
map <leader>oe <action>(org.eclipse.ui.navigate.showInQuickMenu)
map <leader>of <action>(org.jkiss.dbeaver.ui.editors.sql.open.file)

desc <leader>p popup / pin
map <leader>pf <action>(org.eclipse.ui.navigate.openResource)
map <leader>pm <action>(org.eclipse.ui.window.showContextMenu)
map <leader>pp <action>(org.eclipse.ui.edit.text.contentAssist.contextInformation)
map <leader>pt <action>(org.eclipse.ui.window.pinEditor)

desc <leader>q close editor tab
map <leader>q <action>(org.eclipse.ui.file.close)

desc <leader>r run SQL (r statement / s script / e explain / x cancel)
map <leader>rr <action>(org.jkiss.dbeaver.ui.editors.sql.run.statement)
map <leader>rn <action>(org.jkiss.dbeaver.ui.editors.sql.run.statementNew)
map <leader>rs <action>(org.jkiss.dbeaver.ui.editors.sql.run.script)
map <leader>re <action>(org.jkiss.dbeaver.ui.editors.sql.run.explain)
map <leader>rc <action>(org.jkiss.dbeaver.ui.editors.sql.run.count)
map <leader>rx <action>(org.jkiss.dbeaver.ui.editors.sql.cancel.query)

desc <leader>s search / show
map <leader>sa <action>(org.eclipse.ui.window.quickAccess)
map <leader>sf <action>(org.eclipse.ui.navigate.openResource)
map <leader>sp <action>(org.eclipse.search.ui.performTextSearchWorkspace)
map <leader>sr <action>(org.eclipse.search.ui.openSearchDialog)
map <leader>ss <action>(org.eclipse.ui.edit.findReplace)
map <leader>sS <action>(org.jkiss.dbeaver.ui.editors.sql.show.outline)
map <leader>sv <action>(dbmeow.reloadRc)

desc <leader>t toggle (result panel / wrap / whitespace)
map <leader>tf <action>(org.eclipse.ui.window.fullscreenmode)
map <leader>tl <action>(org.eclipse.ui.editors.lineNumberToggle)
map <leader>tm <action>(org.jkiss.dbeaver.ui.editors.sql.maximize.result.panel)
map <leader>tp <action>(org.jkiss.dbeaver.ui.editors.sql.toggle.result.panel)
map <leader>ts <action>(org.eclipse.ui.edit.text.toggleShowWhitespaceCharacters)
map <leader>tw <action>(org.jkiss.dbeaver.ui.editors.sql.word.wrap)

desc <leader>; settings / UI
map <leader>;f <action>(org.eclipse.ui.window.fullscreenmode)
map <leader>;k <action>(org.eclipse.ui.window.showKeyAssist)
map <leader>;l <action>(org.eclipse.ui.editors.lineNumberToggle)
map <leader>;R <action>(org.eclipse.ui.file.restartWorkbench)
map <leader>;s <action>(org.eclipse.ui.window.preferences)

desc <leader>a activate view
map <leader>ab <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.ui.views.BookmarkView))
map <leader>ac <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.ui.console.ConsoleView))
map <leader>ad <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.jkiss.dbeaver.core.databaseNavigator))
map <leader>ae <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.pde.runtime.LogView))
map <leader>ag <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.ui.views.ProgressView))
map <leader>ah <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.team.ui.GenericHistoryView))
map <leader>ao <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.jkiss.dbeaver.core.databaseOutput))
map <leader>ap <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.jkiss.dbeaver.core.projectExplorer))
map <leader>aP <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.ui.views.ProblemView))
map <leader>aq <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.jkiss.dbeaver.core.queryManager))
map <leader>as <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.search.ui.views.SearchView))
map <leader>av <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.jkiss.dbeaver.ui.dashboardView))

" SPC b — bookmarks: m sets a line bookmark, j opens the Bookmarks view
desc <leader>b bookmark (m set / j jump)
map <leader>bm <action>(org.eclipse.ui.edit.addBookmark)
map <leader>bj <action>(org.eclipse.ui.views.showView(org.eclipse.ui.views.showView.viewId=org.eclipse.ui.views.BookmarkView))
map <leader>bb <action>(org.eclipse.ui.window.openEditorDropDown)

" SPC . / SPC , — next / prev annotation, tab, executed query
desc <leader>. next (annotation / tab / query)
map <leader>.e <action>(org.eclipse.ui.navigate.next)
map <leader>.t <action>(org.eclipse.ui.window.nextEditor)
map <leader>.q <action>(org.jkiss.dbeaver.ui.editors.sql.query.next)
desc <leader>, previous (annotation / tab / query)
map <leader>,e <action>(org.eclipse.ui.navigate.previous)
map <leader>,t <action>(org.eclipse.ui.window.previousEditor)
map <leader>,q <action>(org.jkiss.dbeaver.ui.editors.sql.query.prev)

" ============================================================================
" Repeat groups — tap-to-continue transient maps
" ----------------------------------------------------------------------------
" After any binding whose TARGET is listed in a group below (membership is
" the target, not the key), the next keypress is first looked up in that
" group: a member key re-dispatches its target and keeps the run alive; any
" other key (or ESC) ends the run and keeps its normal meaning — nothing is
" swallowed, and there is no timeout. The entering keypad key needn't be a
" member. So: SPC . e then . . , walks annotations; SPC w i then i i i keeps
" zooming. Syntax:
"   repeat <group> <key> <target>     target grammar = the map-line RHS
"   repeat <group> <key> ignore       give a bundled group's key back
" ============================================================================
repeat error . <action>(org.eclipse.ui.navigate.next)
repeat error , <action>(org.eclipse.ui.navigate.previous)
repeat zoom i <action>(org.eclipse.ui.edit.text.zoomIn)
repeat zoom = <action>(org.eclipse.ui.edit.text.zoomIn)
repeat zoom o <action>(org.eclipse.ui.edit.text.zoomOut)
repeat zoom - <action>(org.eclipse.ui.edit.text.zoomOut)
repeat tab n <action>(org.eclipse.ui.window.nextEditor)
repeat tab p <action>(org.eclipse.ui.window.previousEditor)
repeat tab . <action>(org.eclipse.ui.window.nextEditor)
repeat tab , <action>(org.eclipse.ui.window.previousEditor)

" Emacs C-x z: after repeat (SPC x z or '), bare z keeps repeating
repeat replay z repeat
