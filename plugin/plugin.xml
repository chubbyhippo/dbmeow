<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <!-- Bring dbmeow up as soon as the workbench starts, exactly as vrapper
        does (net.sourceforge.vrapper.eclipse plugin.xml:87, IStartup).
        DbmeowStartup then hooks every editor part. -->
   <extension point="org.eclipse.ui.startup">
      <startup class="io.github.chubbyhippo.dbmeow.eclipse.DbmeowStartup"/>
   </extension>
</plugin>
